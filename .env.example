# Postgres container settings.
POSTGRES_DB=testovoe3
POSTGRES_USER=testovoe3
POSTGRES_PASSWORD=change-me-postgres

# Backend database connection.
# Keep password/user/db in sync with the Postgres settings above.
DATABASE_URL=postgresql+asyncpg://testovoe3:change-me-postgres@postgres:5432/testovoe3

# App auth.
# Format: login:password,login2:password2
SESSION_SECRET=change-me-long-random-session-secret
APP_USERS=user1:12345,user2:2407041

# DeepSeek OpenAI-compatible API for rewriting posts.
# Without DEEPSEEK_API_KEY the app can start, but rewrite requests will fail.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# LLM provider selector.
# deepseek keeps the DEEPSEEK_* settings above.
# openai_compatible uses LLM_API_KEY/LLM_BASE_URL/LLM_MODEL.
# ollama uses an OpenAI-compatible local endpoint and does not require an API key.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=45

# Telegram application credentials from https://my.telegram.org.
# Users still log into their own Telegram accounts in the web UI.
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=change-me-telegram-api-hash

# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-with-fernet-key

# Container paths. Defaults are suitable for Docker Compose.
TELEGRAM_SESSIONS_DIR=/app/sessions
MEDIA_DIR=/app/media
MEDIA_URL_PREFIX=/media
